---
import "../styles/global.css";
import { themeInitScript } from "../lib/theme";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Albert Orlando",
  description = "Albert Orlando — personal site.",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline set:html={themeInitScript} />
  </head>
  <body>
    <slot />
    {/* TODO: Motion 12 staggered fade-up on entry is currently driven by the
        CSS `.page.entering` hook + sessionStorage flag in ThemeToggle.astro.
        Revisit if we want JS-driven scroll-linked stagger via Motion. */}
  </body>
</html>
